# Discord bot credentials (required for the bot to read the PolygonX channel).
DISCORD_TOKEN=your-bot-token-here
CHANNEL_ID=your-channel-id-here

# --- Optional: dashboard password protection (HTTP Basic Auth) -------------
# Set BOTH to turn on a login prompt (the browser's native popup, Sonarr-style)
# in front of the whole dashboard and API. Leave BOTH blank to keep the
# original no-auth behavior (fine on a trusted LAN).
# NOTE: Basic Auth sends the credentials on every request, so when exposing the
# dashboard beyond your LAN, put it behind HTTPS (e.g. terminate TLS at your
# reverse proxy) - never over plain http.
DASHBOARD_USER=
DASHBOARD_PASSWORD=

# --- Optional: serve under a sub-path (reverse proxy) ----------------------
# Serve the whole app under a URL base path so it can live at DOMAIN/pogo
# instead of the domain root. Leave blank to serve at "/". Example: /pogo
# The reverse proxy should forward the prefix as-is (do NOT strip it).
URL_BASE=
